<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d1a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💪 Gym Nutrition"
            android:textColor="#e94560"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📴 Offline Mode (15 Foods)"
            android:textColor="#4ecdc4"
            android:textSize="14sp"
            android:paddingBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerFood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/spinner_bg"
            android:padding="14dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="⚖️ Weight (grams)"
            android:textColor="#fff"
            android:textColorHint="#888"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etQty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="🔢 Quantity"
            android:textColor="#fff"
            android:textColorHint="#888"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCalc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 CALCULATE"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#e94560"
            android:padding="16dp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌐 Online Search"
            android:textColor="#e94560"
            android:textSize="14sp"
            android:paddingBottom="8dp"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="🔍 Search any food..."
            android:textColor="#fff"
            android:textColorHint="#888"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 SEARCH ONLINE"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#4ecdc4"
            android:padding="16dp"
            android:layout_marginBottom="12dp"/>

        <ListView
            android:id="@+id/listSearchResults"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#1a1a2e"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/layoutResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvFoodName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Food Name"
                android:textColor="#e94560"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingBottom="12dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="#0d0d1a"
                    android:padding="16dp"
                    android:layout_margin="4dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#e94560"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calories"
                        android:textColor="#888"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="#0d0d1a"
                    android:padding="16dp"
                    android:layout_margin="4dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💪"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvProtein"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 g"
                        android:textColor="#4ecdc4"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protein"
                        android:textColor="#888"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="#0d0d1a"
                    android:padding="16dp"
                    android:layout_margin="4dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥑"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvFat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 g"
                        android:textColor="#f7b731"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fat"
                        android:textColor="#888"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="#0d0d1a"
                    android:padding="16dp"
                    android:layout_margin="4dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍞"
                        android:textSize="24sp"/>

                    <TextView
                        android:id="@+id/tvCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 g"
                        android:textColor="#9b59b6"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carbs"
                        android:textColor="#888"
                        android:textSize="12sp"/>
                </LinearLayout>
            </GridLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎯 Daily Target Progress"
                android:textColor="#4ecdc4"
                android:textSize="14sp"
                android:paddingBottom="8dp"/>

            <TextView
                android:id="@+id/tvProteinPct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Protein: 0%"
                android:textColor="#fff"
                android:paddingBottom="4dp"/>

            <ProgressBar
                android:id="@+id/proteinBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progressTint="#4ecdc4"
                android:progressBackgroundTint="#333"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvCalPct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calories: 0%"
                android:textColor="#fff"
                android:paddingBottom="4dp"/>

            <ProgressBar
                android:id="@+id/calBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progressTint="#f7b731"
                android:progressBackgroundTint="#333"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 Tip"
                android:textColor="#aaa"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:padding="12dp"
                android:background="#0d0d1a"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
